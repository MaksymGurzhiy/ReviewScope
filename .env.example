# =====================================================
# ReviewScope - Environment Configuration
# =====================================================
# Copy this file to `.env` and fill in real values.

# --- Supabase ---
# Project URL (Settings -> API -> Project URL)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Anonymous key (Settings -> API -> anon public)
# Used by frontend (safe to expose)
SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key (Settings -> API -> service_role secret)
# SERVER ONLY. NEVER expose to frontend.
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# JWT secret (Settings -> API -> JWT Settings -> JWT Secret)
# Used to verify tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=super-long-random-string

# --- Direct Postgres connection (Settings -> Database -> Connection string -> URI) ---
# Format: postgresql+asyncpg://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Regex for extra allowed browser origins (Vercel preview URLs match here).
# Example: https://.*\.vercel\.app — use your production frontend URL inside CORS_ORIGINS too.
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=

# --- ML Settings ---
MAX_REVIEWS_PER_ANALYSIS=10000
MIN_REVIEWS_FOR_TOPICS=10
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SENTIMENT_MODEL_MULTILINGUAL=nlptown/bert-base-multilingual-uncased-sentiment
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Storage ---
STORAGE_BUCKET=reviews
LOCAL_UPLOAD_DIR=data/raw

# --- Reports ---
REPORT_LANGUAGE=en
PDF_FONT=Helvetica
